<h2 class="mb-3">読書記録を追加</h2>

<%= bootstrap_form_with url: search_books_path, method: :get, class: 'mb-3' do |f| %>
  <%= f.text_field :q, label: 'タイトル・著者・ISBN' %>
  <%= f.primary '検索' %>
<% end %>

<% if @books %>
  <%= bootstrap_form_with url: books_path, class: 'mb-3' do |f| %>
    <% @books.each do |book| %>
      <%= f.radio_button :book_id, book[:id], label: "#{book[:title]} (#{book[:author]})" %>
    <% end %>
    <%= f.primary '選択', class: 'mt-3 btn btn-primary' %>
  <% end %>
<% end %>
