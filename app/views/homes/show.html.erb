<h2>読書記録</h2>

<%= link_to '追加する', books_path, class: 'btn btn-outline-primary mb-3' %> 

<div class="row row-cols-2">
  <% @readings.each do |reading| %>
    <div class="col">
      <div class="card mb-3">
        <div class="card-body">
          <div class="d-flex">
            <div class="flex-grow-1">
              <h5 class="card-title"><%= link_to reading.book.title, reading_path(reading), class: 'stretched-link text-decoration-none' %></h5>
              <p class="text-body-secondary mb-2"><%= reading.book.author %></p>
              <span class="badge text-bg-<%= status_badge_class(reading.status) %>"><%= reading.status_i18n %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="d-flex justify-content-center">
  <%== @pagy.series_nav(:bootstrap) if @pagy.last > 1 %>
</div>
