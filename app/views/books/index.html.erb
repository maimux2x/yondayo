<div class="accordion mb-4" id="search-accordion">
  <div class="accordion-item">
    <h2 class="accordion-header">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="false" aria-controls="collapseOne">
        追加済みの本を検索
      </button>
    </h2>
    <div id="collapseOne" class="accordion-collapse collapse" data-bs-parent="#search-accordion">
      <div class="accordion-body">
        <%= bootstrap_form_with model: @search, url: books_path, scope: :search, method: :get do |f| %>
          <div class="row row-cols-3 g4 mb-4">
            <%= f.text_field :title, label: 'タイトル' %>
            <%= f.text_field :author, label: '著者' %>
            <%= f.collection_check_boxes :status, Book.statuses_i18n, :first, :last, label: '進捗' %>
            <%= f.date_field :created_at_from, label: '登録日（ここから）'%>
            <%= f.date_field :created_at_to, label: '登録日（ここまで）'%>
          </div>
          <%= f.submit '検索' %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="row row-cols-2 g-4 mb-4">
  <% @books.each do |book| %>
    <div class="col">
      <%= link_to book_path(book), class: "text-decoration-none" do %>
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title text-dark"><%= book.title %></h5>
            <p class="card-text text-muted"><%= book.author %></p>
          </div>
          <div class="card-footer d-flex justify-content-between align-items-center bg-transparent">
            <span class="badge bg-<%= status_badge_class(book.status) %>"><%= book.status_i18n %></span>
            <small class="text-muted"><%= l(book.created_at.to_date) %></small>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center">
    <%== @pagy.series_nav(:bootstrap) %>
  </div>
<% end %>

<%= link_to '追加', new_book_path, class: "btn btn-primary" %>
