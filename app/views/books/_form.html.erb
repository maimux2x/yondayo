<%= bootstrap_form_with model: book, url: [book] do |form| %>
  <%= form.text_field :title, label: 'タイトル', required: true %>
  <%= form.text_field :author, label: '著者', required: true %>
  <%= form.collection_radio_buttons :status, Book.statuses_i18n, :first, :last, label: '進捗' %>
  <%= form.text_area :comment, label: '感想' %>
  <%= form.submit book.persisted? ? '更新する' : '追加する' %>
<% end %>
