<%= bootstrap_form_with model: log, url: [log] do |form| %>
  <%= form.fields_for :book, log.book do |book_form| %>
    <%= book_form.hidden_field :id %>
    <%= book_form.text_field :title, required: true %>
    <%= book_form.text_field :author, required: true %>
  <% end %>

  <%= form.collection_radio_buttons :status, ReadingLog.statuses.keys, :itself, :itself %>
  <%= form.text_area :comment %>
  <%= form.submit %>
<% end %>
