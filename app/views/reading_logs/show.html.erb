<h1 class="mb-4">Reading Log</h1>

<div class="card mb-4">
  <div class="card-body">
    <h2 class="card-title"><%= @log.book.title %></h2>
    <span class="badge bg-<%= status_badge_class(@log.status) %>"><%= @log.status %></span>
    <p class="card-text mt-3"><%= @log.comment %></p>
  </div>
</div>

<% if authenticated? && Current.user == @log.user %>
  <%= link_to :edit, edit_reading_log_path(@log), class: "btn btn-primary me-2" %>
  <%= link_to :delete, reading_log_path(@log), data: { turbo_method: :delete }, class: "btn btn-outline-danger" %>
<% end %>
