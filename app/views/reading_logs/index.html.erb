<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-4">
  <% @logs.each do |log| %>
    <div class="col">
      <%= link_to reading_log_path(log), class: "text-decoration-none" do %>
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title text-dark"><%= log.book.title %></h5>
            <p class="card-text text-muted"><%= log.book.author %></p>
          </div>
          <div class="card-footer d-flex justify-content-between align-items-center bg-transparent">
            <span class="badge bg-<%= status_badge_class(log.status) %>"><%= log.status_i18n %></span>
            <small class="text-muted"><%= l(log.created_at.to_date) %></small>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center">
    <%== @pagy.series_nav(:bootstrap) %>
  </div>
<% end %>

<%= link_to '追加', new_reading_log_path, class: "btn btn-primary" %>
